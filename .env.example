# -----------------------------------------------------------------------
# CRS Insurance Brokers marketing site — environment variables
# Copy to .env.local for development. Never commit real secrets.
# -----------------------------------------------------------------------

# -- Google Analytics 4 ----------------------------------------------------
# The production Measurement ID (G-6BWHLCMP75) is baked into
# ConsentBanner.tsx — no env var needed for production. Set this only to
# OVERRIDE it, e.g. to point a preview deploy at a separate GA property.
# Analytics load only after the visitor accepts cookies via the banner.
NEXT_PUBLIC_GA_ID=

# -- Preview auth gate (proxy.ts) ----------------------------------------
# HTTP Basic Auth wrapper around the whole site for pre-launch sharing.
# When PREVIEW_AUTH_PASS is empty the gate is disabled (default for local
# dev — keeps the inner-loop friction low). Set both vars in the Netlify
# dashboard for the preview deploy. Username can be public; password must
# be treated as a secret.
# AT LAUNCH: clear PREVIEW_AUTH_PASS in Netlify (or delete proxy.ts) — see LAUNCH.md.
PREVIEW_AUTH_USER=crs-preview
PREVIEW_AUTH_PASS=
