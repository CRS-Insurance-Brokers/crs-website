# -----------------------------------------------------------------------
# CRS RIDDOR Helper — environment variables
# Copy to .env.local for development. Never commit real secrets.
# -----------------------------------------------------------------------

# -- Session cookie signing -----------------------------------------------
# Any 32+ character random string. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# -- Supabase (persistence) -----------------------------------------------
# Create a project at https://supabase.com, then copy these from
# Project Settings → API. The service role key grants full DB access —
# keep it server-side only, never in NEXT_PUBLIC_ variables.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Apply schema: supabase db push
# or via SQL editor: run supabase/migrations/0001_incident_reports.sql

# -- Email (submission notification) --------------------------------------
# Wired at the Resend milestone. Leave blank to disable email; submissions
# will still persist to Supabase.
RESEND_API_KEY=
MAIL_FROM=noreply@example.com                # verified Resend sender
HANDLER_EMAIL=claims-test@pmbrtn.com          # preview inbox — never the
                                              # real CRS address in dev

# -- Kitchen sink (component library) -------------------------------------
# Set to 1 on preview deploys to expose /kitchen-sink. Omit in production.
NEXT_PUBLIC_SHOW_KITCHEN_SINK=
